{
  "name": "@repo/database",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client/web": {
      "types": "./dist/client/web.d.ts",
      "default": "./dist/client/web.js"
    },
    "./client/expo": {
      "types": "./dist/client/expo.d.ts",
      "default": "./dist/client/expo.js"
    },
    "./server/next": {
      "types": "./dist/server/next.d.ts",
      "default": "./dist/server/next.js"
    },
    "./server/nest": {
      "types": "./dist/server/nest.d.ts",
      "default": "./dist/server/nest.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "convex": "latest",
    "better-auth": "~1.6.15",
    "@convex-dev/better-auth": "latest",
    "@better-auth/expo": "~1.6.15"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-constants": "~17.0.0"
  },
  "peerDependencies": {
    "next": "^16.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    }
  }
}
