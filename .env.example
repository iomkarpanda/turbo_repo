# ===========================================
# @repo/database — Convex + Better Auth
# ===========================================
# Copy this file to .env and fill in your values.
#
# All packages in this monorepo derive their env vars from
# these root variables. Each app/package reads only the subset
# relevant to its platform (Next.js, Expo, NestJS).

# ---------- Convex Deployment ----------
# Used by: apps/web (NEXT_PUBLIC_*), apps/mobile (EXPO_PUBLIC_*), apps/api (without prefix)
# Convex deployment URL (e.g. https://happy-animal-123.convex.cloud)
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=
CONVEX_URL=
CONVEX_SITE_URL=

# ---------- Better Auth ----------
# Secret used to encrypt and sign auth tokens.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Google OAuth client secret (client ID is hardcoded in auth config).
# Obtain from Google Cloud Console > APIs & Services > Credentials.
BETTER_AUTH_GOOGLE_SECRET=

# ---------- App ----------
# Canonical URL of the application (e.g. https://myapp.com or http://localhost:3000).
# Used as baseURL by Better Auth for redirects and callback URLs.
SITE_URL=

# ---------- Expo Deep Link ----------
# URI scheme for Expo deep linking (default: superapp).
# Must match the scheme in app.json/app.config.ts.
SUPERAPP_SCHEME=superapp
